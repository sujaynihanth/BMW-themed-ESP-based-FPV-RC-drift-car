#include <WiFi.h>
#include <esp_wifi.h>

void setup() {
  Serial.begin(115200);
  delay(1500); 

  WiFi.mode(WIFI_STA);
  WiFi.begin();
  delay(500);

  uint8_t mac[6];
  esp_wifi_get_mac(WIFI_IF_STA, mac);
  
  Serial.println("\n========================================");
  Serial.println("   VALIDATED HARDWARE MAC ADDRESS      ");
  Serial.println("========================================");
  Serial.println("Copy and paste this array into your Transmitter Code:\n");
  
  Serial.printf("uint8_t broadcastAddress[] = {0x%02X, 0x%02X, 0x%02X, 0x%02X, 0x%02X, 0x%02X};\n\n", 
                 mac[0], mac[1], mac[2], mac[3], mac[4], mac[5]);
}

void loop() {}
